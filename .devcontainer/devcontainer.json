{
	"name": "Ygg Scrapper",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/base:bullseye",
	"runArgs": [
		"--dns=1.1.1.1"
	],
	// Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
		"ghcr.io/devcontainers/features/python:1": {
			"version": "3.12"
		}
	},
	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],
	// Utilisez 'postCreateCommand' pour exécuter des commandes après la création du conteneur.
	"postCreateCommand": "sudo apt-get update && sudo apt-get install -y chromium xvfb && pip3 install --user -r requirements.txt"
	// Configurez les propriétés spécifiques à l'outil.
	// "customizations": {},
	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}